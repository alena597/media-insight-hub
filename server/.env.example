PORT=4000
JWT_SECRET=change-me-min-32-chars-random-string

# SQLite database file path (default: server/data.db next to src/)
# DB_PATH=./data.db

# CORS — allowed frontend origin (leave unset to allow all in development)
# FRONTEND_ORIGIN=http://localhost:5173

# Логування (Winston): рівень без перекомпіляції — debug | info | warn | error
# LOG_LEVEL=info
# Каталог файлів логів (за замовчуванням server/logs)
# LOG_DIR=./logs
# Ротація: maxSize (напр. 5m), maxFiles (напр. 14d) — див. winston-daily-rotate-file
# LOG_MAX_FILE_SIZE=5m
# LOG_MAX_FILES=14d
